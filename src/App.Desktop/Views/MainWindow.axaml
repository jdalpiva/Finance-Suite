<Window
    x:Class="SMEFinanceSuite.App.Desktop.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SMEFinanceSuite.App.Desktop.ViewModels"
    x:DataType="vm:MainWindowViewModel"
    Width="1120"
    Height="720"
    MinWidth="980"
    MinHeight="620"
    Title="SME Finance Suite">
  <Grid Margin="24" RowDefinitions="Auto,Auto,*" RowSpacing="16">
    <StackPanel Spacing="6">
      <TextBlock FontSize="28" FontWeight="SemiBold" Text="SME Finance Suite" />
      <TextBlock Opacity="0.72" Text="Sprint 10: evolução de relatórios com granularidade temporal mensal." />
      <TextBlock FontStyle="Italic" Opacity="0.72" Text="{Binding StatusMessage}" />
    </StackPanel>

    <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
      <Border Padding="16" BorderBrush="#30363d" BorderThickness="1" CornerRadius="12">
        <StackPanel Spacing="6">
          <TextBlock FontSize="14" Opacity="0.72" Text="Receita Total" />
          <TextBlock FontSize="26" FontWeight="Bold" Text="{Binding TotalRevenueDisplay}" />
        </StackPanel>
      </Border>

      <Border Grid.Column="1" Padding="16" BorderBrush="#30363d" BorderThickness="1" CornerRadius="12">
        <StackPanel Spacing="6">
          <TextBlock FontSize="14" Opacity="0.72" Text="Despesa Total" />
          <TextBlock FontSize="26" FontWeight="Bold" Text="{Binding TotalExpenseDisplay}" />
        </StackPanel>
      </Border>

      <Border Grid.Column="2" Padding="16" BorderBrush="#30363d" BorderThickness="1" CornerRadius="12">
        <StackPanel Spacing="6">
          <TextBlock FontSize="14" Opacity="0.72" Text="Fluxo de Caixa Líquido" />
          <TextBlock FontSize="26" FontWeight="Bold" Text="{Binding NetCashFlowDisplay}" />
        </StackPanel>
      </Border>

      <Border Grid.Column="3" Padding="16" BorderBrush="#30363d" BorderThickness="1" CornerRadius="12">
        <StackPanel Spacing="6">
          <TextBlock FontSize="14" Opacity="0.72" Text="Base Cadastral" />
          <TextBlock FontSize="26" FontWeight="Bold" Text="{Binding RegistrySummary}" />
        </StackPanel>
      </Border>
    </Grid>

    <Border Grid.Row="2" Padding="12" BorderBrush="#30363d" BorderThickness="1" CornerRadius="12">
      <TabControl>
        <TabItem Header="Lançamentos">
          <Grid Margin="4" ColumnDefinitions="1.8*,1.2*" ColumnSpacing="16">
            <Border Padding="16" BorderBrush="#30363d" BorderThickness="1" CornerRadius="12">
              <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                  <TextBlock FontSize="20" FontWeight="SemiBold" Text="Lançamentos" />
                  <TextBlock Opacity="0.72" Text="{Binding FinancialEntriesModule.EntriesSummary}" />
                </StackPanel>

                <Grid Grid.Row="1" ColumnDefinitions="*,*,Auto,Auto,Auto" ColumnSpacing="8">
                  <TextBox Watermark="De (yyyy-MM-dd)" Text="{Binding FinancialEntriesModule.FilterFrom}" />
                  <TextBox Grid.Column="1" Watermark="Até (yyyy-MM-dd)" Text="{Binding FinancialEntriesModule.FilterTo}" />
                  <ComboBox Grid.Column="2" MinWidth="120" ItemsSource="{Binding FinancialEntriesModule.FilterTypeOptions}" SelectedItem="{Binding FinancialEntriesModule.SelectedFilterType}" />
                  <Button Grid.Column="3" Padding="14,8" Click="OnApplyFiltersClick" Content="Filtrar" IsEnabled="{Binding FinancialEntriesModule.CanApplyFilters}" />
                  <Button Grid.Column="4" Padding="14,8" Click="OnClearFiltersClick" Content="Limpar" IsEnabled="{Binding FinancialEntriesModule.CanClearFilters}" />
                </Grid>

                <Border Grid.Row="2" BorderBrush="#24303a" BorderThickness="1" CornerRadius="10" Padding="0">
                  <Grid RowDefinitions="Auto,*">
                    <Grid ColumnDefinitions="2*,Auto,Auto,2*" ColumnSpacing="8" Margin="10,8,10,8">
                      <TextBlock FontWeight="SemiBold" Text="Descrição" />
                      <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Data" />
                      <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="Valor" />
                      <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="Observações" />
                    </Grid>

                    <ListBox Grid.Row="1" BorderThickness="0" Background="Transparent" ItemsSource="{Binding FinancialEntriesModule.FinancialEntries}" SelectedItem="{Binding FinancialEntriesModule.SelectedFinancialEntry}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:FinancialEntryListItemViewModel">
                          <Border Padding="10,8" BorderBrush="#24303a" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="2*,Auto,Auto,2*" ColumnSpacing="8">
                              <StackPanel Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Description}" TextTrimming="CharacterEllipsis" />
                                <TextBlock FontSize="12" Opacity="0.72" Text="{Binding EntryTypeDisplay}" />
                              </StackPanel>
                              <TextBlock Grid.Column="1" Text="{Binding OccurredOnDisplay}" />
                              <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding AmountDisplay}" />
                              <TextBlock Grid.Column="3" MaxLines="2" Opacity="0.85" Text="{Binding NotesDisplay}" TextTrimming="CharacterEllipsis" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </Grid>
                </Border>
              </Grid>
            </Border>

            <Border Grid.Column="1" Padding="16" BorderBrush="#30363d" BorderThickness="1" CornerRadius="12">
              <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="10">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Lançamento" />

                <StackPanel Grid.Row="1" Spacing="4">
                  <TextBlock Opacity="0.72" Text="Descrição" />
                  <TextBox Text="{Binding FinancialEntriesModule.Form.NewEntryDescription}" />
                </StackPanel>

                <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="8">
                  <StackPanel Spacing="4">
                    <TextBlock Opacity="0.72" Text="Valor" />
                    <TextBox Watermark="1500,50" Text="{Binding FinancialEntriesModule.Form.NewEntryAmount}" />
                  </StackPanel>

                  <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Opacity="0.72" Text="Data" />
                    <TextBox Watermark="yyyy-MM-dd" Text="{Binding FinancialEntriesModule.Form.NewEntryOccurredOn}" />
                  </StackPanel>
                </Grid>

                <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="8">
                  <StackPanel Spacing="4">
                    <TextBlock Opacity="0.72" Text="Tipo" />
                    <ComboBox ItemsSource="{Binding FinancialEntriesModule.Form.FormEntryTypeOptions}" SelectedItem="{Binding FinancialEntriesModule.Form.SelectedFormEntryType}" />
                  </StackPanel>

                  <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Opacity="0.72" Text="Cliente (opcional)" />
                    <ComboBox
                        ItemsSource="{Binding CustomersModule.Customers}"
                        SelectedValue="{Binding FinancialEntriesModule.Form.SelectedCustomerId}"
                        SelectedValueBinding="{Binding Id}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:CustomerListItemViewModel">
                          <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </StackPanel>
                </Grid>

                <StackPanel Grid.Row="4" Spacing="4">
                  <TextBlock Opacity="0.72" Text="Produto/serviço (opcional)" />
                  <ComboBox
                      ItemsSource="{Binding ProductCatalogModule.ActiveProductServices}"
                      SelectedValue="{Binding FinancialEntriesModule.Form.SelectedProductServiceId}"
                      SelectedValueBinding="{Binding Id}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:ProductServiceListItemViewModel">
                        <TextBlock Text="{Binding Name}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="5" Spacing="4">
                  <TextBlock Opacity="0.72" Text="Observações" />
                  <TextBox AcceptsReturn="True" Height="92" Text="{Binding FinancialEntriesModule.Form.NewEntryNotes}" TextWrapping="Wrap" VerticalContentAlignment="Top" />
                </StackPanel>

                <Button Grid.Row="6" Padding="14,10" Click="OnRegisterEntryClick" Content="Cadastrar lançamento" IsEnabled="{Binding FinancialEntriesModule.CanRegister}" />

                <Grid Grid.Row="7" ColumnDefinitions="*,*" ColumnSpacing="8">
                  <Button Padding="14,10" Click="OnUpdateSelectedEntryClick" Content="Atualizar selecionado" IsEnabled="{Binding FinancialEntriesModule.CanUpdateSelected}" />
                  <Button Grid.Column="1" Padding="14,10" Click="OnDeleteSelectedEntryClick" Content="{Binding FinancialEntriesModule.DeleteSelectedButtonLabel}" IsEnabled="{Binding FinancialEntriesModule.CanDeleteSelected}" />
                </Grid>

                <TextBlock Grid.Row="8" IsVisible="{Binding FinancialEntriesModule.IsDeleteConfirmationPending}" Opacity="0.9" Text="Confirmação pendente: clique novamente para excluir o lançamento selecionado." TextWrapping="Wrap" />
              </Grid>
            </Border>
          </Grid>
        </TabItem>

        <TabItem Header="Clientes">
          <Grid Margin="4" ColumnDefinitions="1.3*,1*" ColumnSpacing="16">
            <Border Padding="16" BorderBrush="#30363d" BorderThickness="1" CornerRadius="12">
              <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <TextBlock FontSize="20" FontWeight="SemiBold" Text="Clientes" />
                  <TextBlock Opacity="0.72" Text="{Binding CustomersModule.Summary}" />
                </StackPanel>

                <TextBlock Grid.Row="1" Opacity="0.72" Text="Selecione um cliente para editar ou excluir." />

                <ListBox Grid.Row="2" BorderThickness="0" Background="Transparent" ItemsSource="{Binding CustomersModule.Customers}" SelectedItem="{Binding CustomersModule.SelectedCustomer}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:CustomerListItemViewModel">
                      <Border Padding="10,8" BorderBrush="#24303a" BorderThickness="0,0,0,1">
                        <StackPanel Spacing="2">
                          <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                          <TextBlock FontSize="12" Opacity="0.8" Text="{Binding EmailDisplay}" TextTrimming="CharacterEllipsis" />
                          <TextBlock FontSize="12" Opacity="0.8" Text="{Binding PhoneDisplay}" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>

            <Border Grid.Column="1" Padding="16" BorderBrush="#30363d" BorderThickness="1" CornerRadius="12">
              <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="10">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Formulário de cliente" />

                <StackPanel Grid.Row="1" Spacing="4">
                  <TextBlock Opacity="0.72" Text="Nome" />
                  <TextBox Watermark="Nome do cliente" Text="{Binding CustomersModule.Form.Name}" />
                </StackPanel>

                <StackPanel Grid.Row="2" Spacing="4">
                  <TextBlock Opacity="0.72" Text="Email" />
                  <TextBox Watermark="contato@empresa.com" Text="{Binding CustomersModule.Form.Email}" />
                </StackPanel>

                <StackPanel Grid.Row="3" Spacing="4">
                  <TextBlock Opacity="0.72" Text="Telefone" />
                  <TextBox Watermark="(41) 99999-9999" Text="{Binding CustomersModule.Form.Phone}" />
                </StackPanel>

                <Button Grid.Row="4" Padding="14,10" Click="OnRegisterCustomerClick" Content="Cadastrar cliente" IsEnabled="{Binding CustomersModule.CanRegister}" />

                <TextBlock Grid.Row="5" IsVisible="{Binding CustomersModule.IsDeleteConfirmationPending}" Opacity="0.9" Text="Confirmação pendente: clique novamente para excluir o cliente selecionado." TextWrapping="Wrap" />

                <Grid Grid.Row="6" ColumnDefinitions="*,*" ColumnSpacing="8" VerticalAlignment="Top">
                  <Button Padding="14,10" Click="OnUpdateSelectedCustomerClick" Content="Atualizar selecionado" IsEnabled="{Binding CustomersModule.CanUpdateSelected}" />
                  <Button Grid.Column="1" Padding="14,10" Click="OnDeleteSelectedCustomerClick" Content="{Binding CustomersModule.DeleteSelectedButtonLabel}" IsEnabled="{Binding CustomersModule.CanDeleteSelected}" />
                </Grid>
              </Grid>
            </Border>
          </Grid>
        </TabItem>

        <TabItem Header="Produtos/Serviços">
          <Grid Margin="4" ColumnDefinitions="1.3*,1*" ColumnSpacing="16">
            <Border Padding="16" BorderBrush="#30363d" BorderThickness="1" CornerRadius="12">
              <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <TextBlock FontSize="20" FontWeight="SemiBold" Text="Produtos/Serviços" />
                  <TextBlock Opacity="0.72" Text="{Binding ProductCatalogModule.Summary}" />
                </StackPanel>

                <TextBlock Grid.Row="1" Opacity="0.72" Text="Catálogo completo: cadastro, edição, status ativo/inativo e exclusão protegida." />

                <ListBox Grid.Row="2" BorderThickness="0" Background="Transparent" ItemsSource="{Binding ProductCatalogModule.ProductServices}" SelectedItem="{Binding ProductCatalogModule.SelectedProductService}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:ProductServiceListItemViewModel">
                      <Border Padding="10,8" BorderBrush="#24303a" BorderThickness="0,0,0,1" Opacity="{Binding RowOpacity}">
                        <Grid ColumnDefinitions="2*,Auto,Auto" ColumnSpacing="8">
                          <StackPanel Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                            <TextBlock FontSize="12" Opacity="0.8" Text="{Binding Category}" />
                          </StackPanel>
                          <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock FontSize="12" Opacity="0.8" Text="{Binding KindDisplay}" />
                            <TextBlock FontSize="12" Opacity="0.8" Text="{Binding ActiveDisplay}" />
                          </StackPanel>
                          <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding UnitPriceDisplay}" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>

            <Border Grid.Column="1" Padding="16" BorderBrush="#30363d" BorderThickness="1" CornerRadius="12">
              <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="10">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Cadastro de item" />

                <StackPanel Grid.Row="1" Spacing="4">
                  <TextBlock Opacity="0.72" Text="Nome" />
                  <TextBox Watermark="Nome do produto/serviço" Text="{Binding ProductCatalogModule.Form.Name}" />
                </StackPanel>

                <StackPanel Grid.Row="2" Spacing="4">
                  <TextBlock Opacity="0.72" Text="Categoria" />
                  <TextBox Watermark="Ex.: Serviços, Software, Equipamentos" Text="{Binding ProductCatalogModule.Form.Category}" />
                </StackPanel>

                <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="8">
                  <StackPanel Spacing="4">
                    <TextBlock Opacity="0.72" Text="Preço unitário" />
                    <TextBox Watermark="2500,00" Text="{Binding ProductCatalogModule.Form.UnitPrice}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Opacity="0.72" Text="Tipo" />
                    <ComboBox ItemsSource="{Binding ProductCatalogModule.Form.KindOptions}" SelectedItem="{Binding ProductCatalogModule.Form.SelectedKind}" />
                  </StackPanel>
                </Grid>

                <CheckBox Grid.Row="4" Content="Ativo para novos lançamentos" IsChecked="{Binding ProductCatalogModule.Form.IsActive}" />

                <Button Grid.Row="5" Padding="14,10" Click="OnRegisterProductServiceClick" Content="Cadastrar item" IsEnabled="{Binding ProductCatalogModule.CanRegister}" />

                <Button Grid.Row="6" Padding="14,10" Click="OnToggleSelectedProductServiceActiveClick" Content="{Binding ProductCatalogModule.ToggleSelectedActiveButtonLabel}" IsEnabled="{Binding ProductCatalogModule.CanToggleSelectedActive}" />

                <TextBlock Grid.Row="7" IsVisible="{Binding ProductCatalogModule.IsDeleteConfirmationPending}" Opacity="0.9" Text="Confirmação pendente: clique novamente para excluir o item selecionado." TextWrapping="Wrap" />

                <Grid Grid.Row="8" ColumnDefinitions="*,*" ColumnSpacing="8" VerticalAlignment="Top">
                  <Button Padding="14,10" Click="OnUpdateSelectedProductServiceClick" Content="Atualizar selecionado" IsEnabled="{Binding ProductCatalogModule.CanUpdateSelected}" />
                  <Button Grid.Column="1" Padding="14,10" Click="OnDeleteSelectedProductServiceClick" Content="{Binding ProductCatalogModule.DeleteSelectedButtonLabel}" IsEnabled="{Binding ProductCatalogModule.CanDeleteSelected}" />
                </Grid>
              </Grid>
            </Border>
          </Grid>
        </TabItem>

        <TabItem Header="Relatórios">
          <Grid Margin="4" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" RowSpacing="16">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Spacing="4" VerticalAlignment="Center">
                <TextBlock FontSize="21" FontWeight="SemiBold" Text="Relatórios financeiros" />
                <TextBlock Opacity="0.74" Text="Resumo consolidado, comparativo e breakdowns do período selecionado." />
              </StackPanel>
              <Border Grid.Column="1" Padding="12,8" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="10" Background="#151d26" VerticalAlignment="Center">
                <TextBlock FontWeight="SemiBold" Text="{Binding ReportsModule.Summary}" />
              </Border>
            </Grid>

            <Border Grid.Row="1" Padding="14" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="10" Background="#121a22">
              <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                <TextBlock FontSize="14" FontWeight="SemiBold" Text="Filtros do relatório" />
                <Grid Grid.Row="1" RowDefinitions="Auto,Auto" ColumnDefinitions="*,*,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="6">
                  <TextBlock Opacity="0.78" FontSize="12" Text="Data inicial" />
                  <TextBlock Grid.Column="1" Opacity="0.78" FontSize="12" Text="Data final" />
                  <TextBlock Grid.Column="2" Opacity="0.78" FontSize="12" Text="Tipo" />

                  <TextBox Grid.Row="1" Watermark="De (yyyy-MM-dd)" Text="{Binding ReportsModule.FilterFrom}" />
                  <TextBox Grid.Row="1" Grid.Column="1" Watermark="Até (yyyy-MM-dd)" Text="{Binding ReportsModule.FilterTo}" />
                  <ComboBox Grid.Row="1" Grid.Column="2" MinWidth="130" ItemsSource="{Binding ReportsModule.FilterTypeOptions}" SelectedItem="{Binding ReportsModule.SelectedFilterType}" />
                  <Button Grid.Row="1" Grid.Column="3" Padding="14,8" Click="OnApplyReportFiltersClick" Content="Aplicar período" IsEnabled="{Binding ReportsModule.CanApplyFilters}" />
                  <Button Grid.Row="1" Grid.Column="4" Padding="14,8" Click="OnClearReportFiltersClick" Content="Limpar" IsEnabled="{Binding ReportsModule.CanClearFilters}" />
                  <Button Grid.Row="1" Grid.Column="5" Padding="14,8" Click="OnExportReportCsvClick" Content="Exportar CSV" IsEnabled="{Binding ReportsModule.CanExportCsv}" />
                </Grid>
              </Grid>
            </Border>

            <Border Grid.Row="2" Padding="14" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="10" Background="#111821">
              <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                <TextBlock FontSize="14" FontWeight="SemiBold" Text="Resumo do período selecionado" />
                <Border Grid.Row="1" Padding="10,8" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b">
                  <TextBlock Opacity="0.86" Text="{Binding ReportsModule.PeriodDisplay}" />
                </Border>

                <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="12">
                  <Border Padding="14" BorderBrush="#2f6147" BorderThickness="1" CornerRadius="10" Background="#182920">
                    <StackPanel Spacing="4">
                      <TextBlock FontSize="13" Opacity="0.8" Text="Receitas no período" />
                      <TextBlock FontSize="25" FontWeight="Bold" Text="{Binding ReportsModule.TotalRevenueDisplay}" />
                    </StackPanel>
                  </Border>

                  <Border Grid.Column="1" Padding="14" BorderBrush="#6a3a3f" BorderThickness="1" CornerRadius="10" Background="#2a1b1d">
                    <StackPanel Spacing="4">
                      <TextBlock FontSize="13" Opacity="0.8" Text="Despesas no período" />
                      <TextBlock FontSize="25" FontWeight="Bold" Text="{Binding ReportsModule.TotalExpenseDisplay}" />
                    </StackPanel>
                  </Border>

                  <Border Grid.Column="2" Padding="14" BorderBrush="#30506a" BorderThickness="1" CornerRadius="10" Background="#182632">
                    <StackPanel Spacing="4">
                      <TextBlock FontSize="13" Opacity="0.8" Text="Saldo no período" />
                      <TextBlock FontSize="25" FontWeight="Bold" Text="{Binding ReportsModule.NetBalanceDisplay}" />
                    </StackPanel>
                  </Border>
                </Grid>
              </Grid>
            </Border>

            <Border Grid.Row="3" Padding="14" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="10" Background="#121821">
              <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="10">
                <TextBlock FontSize="14" FontWeight="SemiBold" Text="Comparativo com período anterior" />

                <StackPanel Grid.Row="1" Spacing="3">
                  <TextBlock FontSize="12" Opacity="0.74" Text="Regra: período anterior imediato com a mesma duração do período selecionado." TextWrapping="Wrap" />
                  <TextBlock FontSize="12" Opacity="0.74" Text="Indicadores: ▲ alta | ▼ queda | ■ estável/indisponível." TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Row="2" Padding="10,8" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b">
                  <TextBlock Opacity="0.84" Text="{Binding ReportsModule.PeriodComparisonDisplay}" TextWrapping="Wrap" />
                </Border>

                <Grid Grid.Row="3" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                  <Border Padding="10,8" BorderBrush="#2d3a48" BorderThickness="1" CornerRadius="8" Background="#141c25">
                    <Grid ColumnDefinitions="110,*" ColumnSpacing="12">
                      <TextBlock FontWeight="SemiBold" Text="Receita" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1" Text="{Binding ReportsModule.RevenueComparisonDisplay}" TextWrapping="Wrap" />
                    </Grid>
                  </Border>

                  <Border Grid.Row="1" Padding="10,8" BorderBrush="#2d3a48" BorderThickness="1" CornerRadius="8" Background="#141c25">
                    <Grid ColumnDefinitions="110,*" ColumnSpacing="12">
                      <TextBlock FontWeight="SemiBold" Text="Despesa" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1" Text="{Binding ReportsModule.ExpenseComparisonDisplay}" TextWrapping="Wrap" />
                    </Grid>
                  </Border>

                  <Border Grid.Row="2" Padding="10,8" BorderBrush="#2d3a48" BorderThickness="1" CornerRadius="8" Background="#141c25">
                    <Grid ColumnDefinitions="110,*" ColumnSpacing="12">
                      <TextBlock FontWeight="SemiBold" Text="Saldo" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1" Text="{Binding ReportsModule.NetBalanceComparisonDisplay}" TextWrapping="Wrap" />
                    </Grid>
                  </Border>
                </Grid>
              </Grid>
            </Border>

            <Border Grid.Row="4" Padding="14" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="10" Background="#111821">
              <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
                <TextBlock FontSize="14" FontWeight="SemiBold" Text="Breakdown mensal" />

                <Border Grid.Row="1" Padding="10,7" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b">
                  <Grid ColumnDefinitions="2*,1.2*,1.2*,1.2*" ColumnSpacing="10">
                    <TextBlock FontWeight="SemiBold" Opacity="0.8" Text="Mês" />
                    <TextBlock Grid.Column="1" FontWeight="SemiBold" HorizontalAlignment="Right" Opacity="0.8" Text="Receitas" />
                    <TextBlock Grid.Column="2" FontWeight="SemiBold" HorizontalAlignment="Right" Opacity="0.8" Text="Despesas" />
                    <TextBlock Grid.Column="3" FontWeight="SemiBold" HorizontalAlignment="Right" Opacity="0.8" Text="Saldo" />
                  </Grid>
                </Border>

                <ListBox Grid.Row="2" BorderThickness="0" Background="Transparent" ItemsSource="{Binding ReportsModule.BreakdownByMonth}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:FinancialReportMonthlyBreakdownItemViewModel">
                      <Border Padding="11,9" BorderBrush="#24303a" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="2*,1.2*,1.2*,1.2*" ColumnSpacing="10">
                          <TextBlock FontWeight="SemiBold" Text="{Binding MonthDisplay}" />
                          <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding TotalRevenueDisplay}" />
                          <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding TotalExpenseDisplay}" />
                          <TextBlock Grid.Column="3" HorizontalAlignment="Right" Text="{Binding NetBalanceDisplay}" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>

            <Grid Grid.Row="5" ColumnDefinitions="*,*" ColumnSpacing="16">
              <Border Padding="14" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="10" Background="#111821">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
                  <TextBlock FontSize="14" FontWeight="SemiBold" Text="Breakdown por cliente" />

                  <Border Grid.Row="1" Padding="10,7" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b">
                    <Grid ColumnDefinitions="2*,1.2*,1.2*,1.2*" ColumnSpacing="10">
                      <TextBlock FontWeight="SemiBold" Opacity="0.8" Text="Cliente" />
                      <TextBlock Grid.Column="1" FontWeight="SemiBold" HorizontalAlignment="Right" Opacity="0.8" Text="Receitas" />
                      <TextBlock Grid.Column="2" FontWeight="SemiBold" HorizontalAlignment="Right" Opacity="0.8" Text="Despesas" />
                      <TextBlock Grid.Column="3" FontWeight="SemiBold" HorizontalAlignment="Right" Opacity="0.8" Text="Saldo" />
                    </Grid>
                  </Border>

                  <ListBox Grid.Row="2" BorderThickness="0" Background="Transparent" ItemsSource="{Binding ReportsModule.BreakdownByCustomer}">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:FinancialReportBreakdownItemViewModel">
                        <Border Padding="11,9" BorderBrush="#24303a" BorderThickness="0,0,0,1">
                          <Grid ColumnDefinitions="2*,1.2*,1.2*,1.2*" ColumnSpacing="10">
                            <TextBlock FontWeight="SemiBold" Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding TotalRevenueDisplay}" />
                            <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding TotalExpenseDisplay}" />
                            <TextBlock Grid.Column="3" HorizontalAlignment="Right" Text="{Binding NetBalanceDisplay}" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>
              </Border>

              <Border Grid.Column="1" Padding="14" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="10" Background="#111821">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
                  <TextBlock FontSize="14" FontWeight="SemiBold" Text="Breakdown por produto/serviço" />

                  <Border Grid.Row="1" Padding="10,7" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b">
                    <Grid ColumnDefinitions="2*,1.2*,1.2*,1.2*" ColumnSpacing="10">
                      <TextBlock FontWeight="SemiBold" Opacity="0.8" Text="Produto/Serviço" />
                      <TextBlock Grid.Column="1" FontWeight="SemiBold" HorizontalAlignment="Right" Opacity="0.8" Text="Receitas" />
                      <TextBlock Grid.Column="2" FontWeight="SemiBold" HorizontalAlignment="Right" Opacity="0.8" Text="Despesas" />
                      <TextBlock Grid.Column="3" FontWeight="SemiBold" HorizontalAlignment="Right" Opacity="0.8" Text="Saldo" />
                    </Grid>
                  </Border>

                  <ListBox Grid.Row="2" BorderThickness="0" Background="Transparent" ItemsSource="{Binding ReportsModule.BreakdownByProductService}">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:FinancialReportBreakdownItemViewModel">
                        <Border Padding="11,9" BorderBrush="#24303a" BorderThickness="0,0,0,1">
                          <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="2*,1.2*,1.2*,1.2*" ColumnSpacing="10">
                            <TextBlock FontWeight="SemiBold" Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding TotalRevenueDisplay}" />
                            <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding TotalExpenseDisplay}" />
                            <TextBlock Grid.Column="3" HorizontalAlignment="Right" Text="{Binding NetBalanceDisplay}" />
                            <TextBlock Grid.Row="1" FontSize="12" Opacity="0.72" Text="{Binding CategoryDisplay}" TextTrimming="CharacterEllipsis" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>
              </Border>
            </Grid>
          </Grid>
        </TabItem>
      </TabControl>
    </Border>
  </Grid>
</Window>
