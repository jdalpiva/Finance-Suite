<Window
    x:Class="SMEFinanceSuite.App.Desktop.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SMEFinanceSuite.App.Desktop.ViewModels"
    x:DataType="vm:MainWindowViewModel"
    Width="1120"
    Height="720"
    MinWidth="980"
    MinHeight="620"
    Title="SME Finance Suite">
  <Window.Styles>
    <Style Selector="TabItem">
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="Margin" Value="0,0,6,0" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="#2d3b4a" />
      <Setter Property="Background" Value="#111821" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TabItem:pointerover">
      <Setter Property="Background" Value="#17222f" />
      <Setter Property="BorderBrush" Value="#41556b" />
    </Style>

    <Style Selector="TabItem:selected">
      <Setter Property="Background" Value="#1e2f42" />
      <Setter Property="BorderBrush" Value="#678eb5" />
    </Style>

    <Style Selector="TabItem:focus-visible">
      <Setter Property="BorderBrush" Value="#9ac7f3" />
      <Setter Property="Background" Value="#263b52" />
    </Style>

    <Style Selector="TextBox">
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="#415163" />
      <Setter Property="Background" Value="#0f1620" />
    </Style>

    <Style Selector="TextBox:pointerover">
      <Setter Property="BorderBrush" Value="#5f758d" />
    </Style>

    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="#7aa6d1" />
      <Setter Property="Background" Value="#132131" />
    </Style>

    <Style Selector="TextBox:focus-visible">
      <Setter Property="BorderBrush" Value="#9ac7f3" />
      <Setter Property="Background" Value="#16293d" />
    </Style>

    <Style Selector="ComboBox">
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="#415163" />
      <Setter Property="Background" Value="#0f1620" />
    </Style>

    <Style Selector="ComboBox:pointerover">
      <Setter Property="BorderBrush" Value="#5f758d" />
    </Style>

    <Style Selector="ComboBox:focus">
      <Setter Property="BorderBrush" Value="#7aa6d1" />
      <Setter Property="Background" Value="#132131" />
    </Style>

    <Style Selector="ComboBox:focus-visible">
      <Setter Property="BorderBrush" Value="#9ac7f3" />
      <Setter Property="Background" Value="#16293d" />
    </Style>

    <Style Selector="ListBox">
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style Selector="ListBox:focus-visible">
      <Setter Property="BorderBrush" Value="#7fb1df" />
      <Setter Property="Background" Value="#101c2a" />
    </Style>

    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,0,2" />
      <Setter Property="IsTabStop" Value="False" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ListBoxItem:pointerover">
      <Setter Property="Background" Value="#172431" />
      <Setter Property="BorderBrush" Value="#3d5268" />
    </Style>

    <Style Selector="ListBoxItem:selected">
      <Setter Property="Background" Value="#21384d" />
      <Setter Property="BorderBrush" Value="#5c83ab" />
    </Style>

    <Style Selector="ListBoxItem:selected:pointerover">
      <Setter Property="Background" Value="#29445f" />
      <Setter Property="BorderBrush" Value="#7aa6d1" />
    </Style>

    <Style Selector="ListBoxItem:focus-visible">
      <Setter Property="BorderBrush" Value="#9ac7f3" />
      <Setter Property="Background" Value="#243a4f" />
    </Style>

    <Style Selector="CheckBox">
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="CheckBox:focus-visible">
      <Setter Property="BorderBrush" Value="#9ac7f3" />
      <Setter Property="Background" Value="#1a2a3c" />
    </Style>

    <Style Selector="ListBoxItem:selected:focus-visible">
      <Setter Property="BorderBrush" Value="#b5dcff" />
      <Setter Property="Background" Value="#2c4763" />
    </Style>

    <Style Selector="Button">
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="#5a6775" />
      <Setter Property="Background" Value="#223142" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="#2b3d51" />
      <Setter Property="BorderBrush" Value="#76879a" />
    </Style>

    <Style Selector="Button:disabled">
      <Setter Property="Opacity" Value="0.6" />
    </Style>

    <Style Selector="Button:focus-visible">
      <Setter Property="BorderBrush" Value="#9ac7f3" />
      <Setter Property="Background" Value="#334c63" />
    </Style>

    <Style Selector="Button.primary-action">
      <Setter Property="Background" Value="#20482f" />
      <Setter Property="BorderBrush" Value="#3f7a53" />
    </Style>

    <Style Selector="Button.primary-action:pointerover">
      <Setter Property="Background" Value="#285b3b" />
      <Setter Property="BorderBrush" Value="#5aa071" />
    </Style>

    <Style Selector="Button.primary-action:focus-visible">
      <Setter Property="BorderBrush" Value="#b6e2c5" />
      <Setter Property="Background" Value="#327549" />
    </Style>

    <Style Selector="Button.secondary-action">
      <Setter Property="Background" Value="#223142" />
      <Setter Property="BorderBrush" Value="#5a6775" />
    </Style>

    <Style Selector="Button.secondary-action:pointerover">
      <Setter Property="Background" Value="#2f4359" />
      <Setter Property="BorderBrush" Value="#7f96ad" />
    </Style>

    <Style Selector="Button.secondary-action:focus-visible">
      <Setter Property="BorderBrush" Value="#9ac7f3" />
      <Setter Property="Background" Value="#3f5e7c" />
    </Style>

    <Style Selector="Button.destructive-action">
      <Setter Property="Background" Value="#4a1f24" />
      <Setter Property="BorderBrush" Value="#8f424b" />
    </Style>

    <Style Selector="Button.destructive-action:pointerover">
      <Setter Property="Background" Value="#5f272f" />
      <Setter Property="BorderBrush" Value="#b35a66" />
    </Style>

    <Style Selector="Button.destructive-action:focus-visible">
      <Setter Property="BorderBrush" Value="#f0a9b2" />
      <Setter Property="Background" Value="#7b3841" />
    </Style>
  </Window.Styles>

  <Grid Margin="24" RowDefinitions="Auto,Auto,*" RowSpacing="16">
    <StackPanel Spacing="6">
      <TextBlock FontSize="28" FontWeight="SemiBold" Text="SME Finance Suite" />
      <TextBlock Opacity="0.72" Text="Pré-release leve: operação local com lançamentos, cadastros, relatórios e exportação CSV." />
      <TextBlock FontStyle="Italic" Opacity="0.72" Text="{Binding StatusMessage}" />
    </StackPanel>

    <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
      <Border Padding="16" BorderBrush="#30363d" BorderThickness="1" CornerRadius="12">
        <StackPanel Spacing="6">
          <TextBlock FontSize="14" Opacity="0.72" Text="Receita Total" />
          <TextBlock FontSize="26" FontWeight="Bold" Text="{Binding TotalRevenueDisplay}" />
        </StackPanel>
      </Border>

      <Border Grid.Column="1" Padding="16" BorderBrush="#30363d" BorderThickness="1" CornerRadius="12">
        <StackPanel Spacing="6">
          <TextBlock FontSize="14" Opacity="0.72" Text="Despesa Total" />
          <TextBlock FontSize="26" FontWeight="Bold" Text="{Binding TotalExpenseDisplay}" />
        </StackPanel>
      </Border>

      <Border Grid.Column="2" Padding="16" BorderBrush="#30363d" BorderThickness="1" CornerRadius="12">
        <StackPanel Spacing="6">
          <TextBlock FontSize="14" Opacity="0.72" Text="Fluxo de Caixa Líquido" />
          <TextBlock FontSize="26" FontWeight="Bold" Text="{Binding NetCashFlowDisplay}" />
        </StackPanel>
      </Border>

      <Border Grid.Column="3" Padding="16" BorderBrush="#30363d" BorderThickness="1" CornerRadius="12">
        <StackPanel Spacing="6">
          <TextBlock FontSize="14" Opacity="0.72" Text="Base Cadastral" />
          <TextBlock FontSize="26" FontWeight="Bold" Text="{Binding RegistrySummary}" />
        </StackPanel>
      </Border>
    </Grid>

    <Border Grid.Row="2" Padding="12" BorderBrush="#30363d" BorderThickness="1" CornerRadius="12">
      <TabControl TabIndex="1">
        <TabItem Header="Lançamentos">
          <Grid Margin="4" ColumnDefinitions="1.8*,1.2*" ColumnSpacing="16">
            <Border Padding="14" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="12" Background="#111821">
              <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                  <StackPanel Spacing="3" VerticalAlignment="Center">
                    <TextBlock FontSize="21" FontWeight="SemiBold" Text="Lançamentos" />
                    <TextBlock Opacity="0.74" Text="Gestão de receitas e despesas do período com filtros rápidos." />
                  </StackPanel>
                  <Border Grid.Column="1" Padding="12,8" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="10" Background="#151d26" VerticalAlignment="Center">
                    <TextBlock FontWeight="SemiBold" Text="{Binding FinancialEntriesModule.EntriesSummary}" />
                  </Border>
                </Grid>

                <Border Grid.Row="1" Padding="12" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="10" Background="#121a22">
                  <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
                    <TextBlock FontSize="14" FontWeight="SemiBold" Text="Filtros de lançamentos" />
                    <Grid Grid.Row="1" RowDefinitions="Auto,Auto" ColumnDefinitions="*,*,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                      <TextBlock Opacity="0.78" FontSize="12" Text="Data inicial" />
                      <TextBlock Grid.Column="1" Opacity="0.78" FontSize="12" Text="Data final" />
                      <TextBlock Grid.Column="2" Opacity="0.78" FontSize="12" Text="Tipo" />

                      <TextBox Grid.Row="1" TabIndex="10" Watermark="De (yyyy-MM-dd)" Text="{Binding FinancialEntriesModule.FilterFrom}" />
                      <TextBox Grid.Row="1" Grid.Column="1" TabIndex="11" Watermark="Até (yyyy-MM-dd)" Text="{Binding FinancialEntriesModule.FilterTo}" />
                      <ComboBox Grid.Row="1" Grid.Column="2" TabIndex="12" MinWidth="120" ItemsSource="{Binding FinancialEntriesModule.FilterTypeOptions}" SelectedItem="{Binding FinancialEntriesModule.SelectedFilterType}" />
                      <Button Classes="primary-action" Grid.Row="1" Grid.Column="3" TabIndex="13" Padding="14,8" Click="OnApplyFiltersClick" Content="Filtrar" IsEnabled="{Binding FinancialEntriesModule.CanApplyFilters}" />
                      <Button Classes="secondary-action" Grid.Row="1" Grid.Column="4" TabIndex="14" Padding="14,8" Click="OnClearFiltersClick" Content="Limpar" IsEnabled="{Binding FinancialEntriesModule.CanClearFilters}" />
                    </Grid>
                  </Grid>
                </Border>

                <Border Grid.Row="2" Padding="12" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="10" Background="#121821">
                  <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">
                    <TextBlock FontSize="14" FontWeight="SemiBold" Text="Lista de lançamentos" />
                    <Border Grid.Row="1" Padding="10,7" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b">
                      <Grid ColumnDefinitions="2.2*,1.1*,1.1*,2.2*" ColumnSpacing="8">
                        <TextBlock FontWeight="SemiBold" Opacity="0.8" Text="Descrição" />
                        <TextBlock Grid.Column="1" FontWeight="SemiBold" HorizontalAlignment="Center" Opacity="0.8" Text="Data" />
                        <TextBlock Grid.Column="2" FontWeight="SemiBold" HorizontalAlignment="Right" Opacity="0.8" Text="Valor" />
                        <TextBlock Grid.Column="3" FontWeight="SemiBold" Opacity="0.8" Text="Observações" />
                      </Grid>
                    </Border>

                    <ListBox Grid.Row="2" TabIndex="20" BorderThickness="1" Background="Transparent" ItemsSource="{Binding FinancialEntriesModule.FinancialEntries}" SelectedItem="{Binding FinancialEntriesModule.SelectedFinancialEntry}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:FinancialEntryListItemViewModel">
                          <Border Padding="11,9" BorderBrush="#24303a" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="2.2*,1.1*,1.1*,2.2*" ColumnSpacing="8">
                              <StackPanel Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Description}" TextTrimming="CharacterEllipsis" />
                                <TextBlock FontSize="12" Opacity="0.72" Text="{Binding EntryTypeDisplay}" />
                              </StackPanel>
                              <TextBlock Grid.Column="1" HorizontalAlignment="Center" Text="{Binding OccurredOnDisplay}" />
                              <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding AmountDisplay}" />
                              <TextBlock Grid.Column="3" MaxLines="2" Opacity="0.85" Text="{Binding NotesDisplay}" TextTrimming="CharacterEllipsis" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </Grid>
                </Border>
              </Grid>
            </Border>

            <Border Grid.Column="1" Padding="14" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="12" Background="#111821">
              <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="10">
                <StackPanel Spacing="3">
                  <TextBlock FontSize="21" FontWeight="SemiBold" Text="Lançamento" />
                  <TextBlock Opacity="0.74" Text="Cadastro e manutenção de um lançamento por vez." />
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="4">
                  <TextBlock Opacity="0.78" Text="Descrição" />
                  <TextBox TabIndex="30" Text="{Binding FinancialEntriesModule.Form.NewEntryDescription}" />
                </StackPanel>

                <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="8">
                  <StackPanel Spacing="4">
                    <TextBlock Opacity="0.78" Text="Valor" />
                    <TextBox TabIndex="31" Watermark="1500,50" Text="{Binding FinancialEntriesModule.Form.NewEntryAmount}" />
                  </StackPanel>

                  <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Opacity="0.78" Text="Data" />
                    <TextBox TabIndex="32" Watermark="yyyy-MM-dd" Text="{Binding FinancialEntriesModule.Form.NewEntryOccurredOn}" />
                  </StackPanel>
                </Grid>

                <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="8">
                  <StackPanel Spacing="4">
                    <TextBlock Opacity="0.78" Text="Tipo" />
                    <ComboBox TabIndex="33" ItemsSource="{Binding FinancialEntriesModule.Form.FormEntryTypeOptions}" SelectedItem="{Binding FinancialEntriesModule.Form.SelectedFormEntryType}" />
                  </StackPanel>

                  <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Opacity="0.78" Text="Cliente (opcional)" />
                    <ComboBox
                        TabIndex="34"
                        ItemsSource="{Binding CustomersModule.Customers}"
                        SelectedValue="{Binding FinancialEntriesModule.Form.SelectedCustomerId}"
                        SelectedValueBinding="{Binding Id}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:CustomerListItemViewModel">
                          <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </StackPanel>
                </Grid>

                <StackPanel Grid.Row="4" Spacing="4">
                  <TextBlock Opacity="0.78" Text="Produto/serviço (opcional)" />
                  <ComboBox
                      TabIndex="35"
                      ItemsSource="{Binding ProductCatalogModule.ActiveProductServices}"
                      SelectedValue="{Binding FinancialEntriesModule.Form.SelectedProductServiceId}"
                      SelectedValueBinding="{Binding Id}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:ProductServiceListItemViewModel">
                        <TextBlock Text="{Binding Name}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="5" Spacing="4">
                  <TextBlock Opacity="0.78" Text="Observações" />
                  <TextBox TabIndex="36" AcceptsReturn="True" Height="92" Text="{Binding FinancialEntriesModule.Form.NewEntryNotes}" TextWrapping="Wrap" VerticalContentAlignment="Top" />
                </StackPanel>

                <Border Grid.Row="6" Padding="8" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b">
                  <Button Classes="primary-action" TabIndex="37" Padding="14,10" Click="OnRegisterEntryClick" Content="Cadastrar lançamento" IsEnabled="{Binding FinancialEntriesModule.CanRegister}" />
                </Border>

                <Border Grid.Row="7" Padding="8" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b">
                  <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Classes="secondary-action" TabIndex="38" Padding="14,10" Click="OnUpdateSelectedEntryClick" Content="Atualizar selecionado" IsEnabled="{Binding FinancialEntriesModule.CanUpdateSelected}" />
                    <Button Classes="destructive-action" Grid.Column="1" TabIndex="39" Padding="14,10" Click="OnDeleteSelectedEntryClick" Content="{Binding FinancialEntriesModule.DeleteSelectedButtonLabel}" IsEnabled="{Binding FinancialEntriesModule.CanDeleteSelected}" />
                  </Grid>
                </Border>

                <Border Grid.Row="8" IsVisible="{Binding FinancialEntriesModule.IsDeleteConfirmationPending}" Padding="10,8" BorderBrush="#6a3a3f" BorderThickness="1" CornerRadius="8" Background="#2a1b1d">
                  <TextBlock Opacity="0.9" Text="Confirmação pendente: clique novamente para excluir o lançamento selecionado." TextWrapping="Wrap" />
                </Border>
              </Grid>
            </Border>
          </Grid>
        </TabItem>

        <TabItem Header="Clientes">
          <Grid Margin="4" ColumnDefinitions="1.3*,1*" ColumnSpacing="16">
            <Border Padding="14" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="12" Background="#111821">
              <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                  <StackPanel Spacing="3" VerticalAlignment="Center">
                    <TextBlock FontSize="21" FontWeight="SemiBold" Text="Clientes" />
                    <TextBlock Opacity="0.74" Text="Cadastro e manutenção de clientes para vincular lançamentos." />
                  </StackPanel>
                  <Border Grid.Column="1" Padding="12,8" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="10" Background="#151d26" VerticalAlignment="Center">
                    <TextBlock FontWeight="SemiBold" Text="{Binding CustomersModule.Summary}" />
                  </Border>
                </Grid>

                <Border Grid.Row="1" Padding="10,8" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b">
                  <TextBlock Opacity="0.84" Text="Selecione um cliente para editar ou excluir." />
                </Border>

                <Border Grid.Row="2" Padding="12" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="10" Background="#121821">
                  <Grid RowDefinitions="Auto,*" RowSpacing="8">
                    <Border Padding="10,7" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b">
                      <Grid ColumnDefinitions="1.2*,1.4*,1*" ColumnSpacing="8">
                        <TextBlock FontWeight="SemiBold" Opacity="0.8" Text="Nome" />
                        <TextBlock Grid.Column="1" FontWeight="SemiBold" Opacity="0.8" Text="Email" />
                        <TextBlock Grid.Column="2" FontWeight="SemiBold" Opacity="0.8" Text="Telefone" />
                      </Grid>
                    </Border>

                    <ListBox Grid.Row="1" TabIndex="10" BorderThickness="1" Background="Transparent" ItemsSource="{Binding CustomersModule.Customers}" SelectedItem="{Binding CustomersModule.SelectedCustomer}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:CustomerListItemViewModel">
                          <Border Padding="11,9" BorderBrush="#24303a" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="1.2*,1.4*,1*" ColumnSpacing="8">
                              <TextBlock FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                              <TextBlock Grid.Column="1" Opacity="0.85" Text="{Binding EmailDisplay}" TextTrimming="CharacterEllipsis" />
                              <TextBlock Grid.Column="2" Opacity="0.85" Text="{Binding PhoneDisplay}" TextTrimming="CharacterEllipsis" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </Grid>
                </Border>
              </Grid>
            </Border>

            <Border Grid.Column="1" Padding="14" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="12" Background="#111821">
              <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="10">
                <StackPanel Spacing="3">
                  <TextBlock FontSize="21" FontWeight="SemiBold" Text="Formulário de cliente" />
                  <TextBlock Opacity="0.74" Text="Preencha os dados para cadastro ou atualização do cliente selecionado." />
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="4">
                  <TextBlock Opacity="0.78" Text="Nome" />
                  <TextBox TabIndex="20" Watermark="Nome do cliente" Text="{Binding CustomersModule.Form.Name}" />
                </StackPanel>

                <StackPanel Grid.Row="2" Spacing="4">
                  <TextBlock Opacity="0.78" Text="Email" />
                  <TextBox TabIndex="21" Watermark="contato@empresa.com" Text="{Binding CustomersModule.Form.Email}" />
                </StackPanel>

                <StackPanel Grid.Row="3" Spacing="4">
                  <TextBlock Opacity="0.78" Text="Telefone" />
                  <TextBox TabIndex="22" Watermark="(41) 99999-9999" Text="{Binding CustomersModule.Form.Phone}" />
                </StackPanel>

                <Border Grid.Row="4" Padding="8" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b">
                  <Button Classes="primary-action" TabIndex="23" Padding="14,10" Click="OnRegisterCustomerClick" Content="Cadastrar cliente" IsEnabled="{Binding CustomersModule.CanRegister}" />
                </Border>

                <Border Grid.Row="5" IsVisible="{Binding CustomersModule.IsDeleteConfirmationPending}" Padding="10,8" BorderBrush="#6a3a3f" BorderThickness="1" CornerRadius="8" Background="#2a1b1d">
                  <TextBlock Opacity="0.9" Text="Confirmação pendente: clique novamente para excluir o cliente selecionado." TextWrapping="Wrap" />
                </Border>

                <Border Grid.Row="6" Padding="8" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b" VerticalAlignment="Top">
                  <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Classes="secondary-action" TabIndex="24" Padding="14,10" Click="OnUpdateSelectedCustomerClick" Content="Atualizar selecionado" IsEnabled="{Binding CustomersModule.CanUpdateSelected}" />
                    <Button Classes="destructive-action" Grid.Column="1" TabIndex="25" Padding="14,10" Click="OnDeleteSelectedCustomerClick" Content="{Binding CustomersModule.DeleteSelectedButtonLabel}" IsEnabled="{Binding CustomersModule.CanDeleteSelected}" />
                  </Grid>
                </Border>
              </Grid>
            </Border>
          </Grid>
        </TabItem>

        <TabItem Header="Produtos/Serviços">
          <Grid Margin="4" ColumnDefinitions="1.3*,1*" ColumnSpacing="16">
            <Border Padding="14" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="12" Background="#111821">
              <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                  <StackPanel Spacing="3" VerticalAlignment="Center">
                    <TextBlock FontSize="21" FontWeight="SemiBold" Text="Produtos/Serviços" />
                    <TextBlock Opacity="0.74" Text="Catálogo de itens usados nos lançamentos financeiros." />
                  </StackPanel>
                  <Border Grid.Column="1" Padding="12,8" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="10" Background="#151d26" VerticalAlignment="Center">
                    <TextBlock FontWeight="SemiBold" Text="{Binding ProductCatalogModule.Summary}" />
                  </Border>
                </Grid>

                <Border Grid.Row="1" Padding="10,8" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b">
                  <TextBlock Opacity="0.84" Text="Catálogo completo: cadastro, edição, status ativo/inativo e exclusão protegida." />
                </Border>

                <Border Grid.Row="2" Padding="12" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="10" Background="#121821">
                  <Grid RowDefinitions="Auto,*" RowSpacing="8">
                    <Border Padding="10,7" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b">
                      <Grid ColumnDefinitions="2*,1.1*,1*" ColumnSpacing="8">
                        <TextBlock FontWeight="SemiBold" Opacity="0.8" Text="Item" />
                        <TextBlock Grid.Column="1" FontWeight="SemiBold" Opacity="0.8" Text="Status" />
                        <TextBlock Grid.Column="2" FontWeight="SemiBold" HorizontalAlignment="Right" Opacity="0.8" Text="Preço" />
                      </Grid>
                    </Border>

                    <ListBox Grid.Row="1" TabIndex="10" BorderThickness="1" Background="Transparent" ItemsSource="{Binding ProductCatalogModule.ProductServices}" SelectedItem="{Binding ProductCatalogModule.SelectedProductService}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProductServiceListItemViewModel">
                          <Border Padding="11,9" BorderBrush="#24303a" BorderThickness="0,0,0,1" Opacity="{Binding RowOpacity}">
                            <Grid ColumnDefinitions="2*,1.1*,1*" ColumnSpacing="8">
                              <StackPanel Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                <TextBlock FontSize="12" Opacity="0.8" Text="{Binding Category}" TextTrimming="CharacterEllipsis" />
                              </StackPanel>
                              <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock FontSize="12" Opacity="0.8" Text="{Binding KindDisplay}" />
                                <TextBlock FontSize="12" Opacity="0.8" Text="{Binding ActiveDisplay}" />
                              </StackPanel>
                              <TextBlock Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding UnitPriceDisplay}" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </Grid>
                </Border>
              </Grid>
            </Border>

            <Border Grid.Column="1" Padding="14" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="12" Background="#111821">
              <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="10">
                <StackPanel Spacing="3">
                  <TextBlock FontSize="21" FontWeight="SemiBold" Text="Cadastro de item" />
                  <TextBlock Opacity="0.74" Text="Preencha os campos para cadastro ou atualização do item selecionado." />
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="4">
                  <TextBlock Opacity="0.78" Text="Nome" />
                  <TextBox TabIndex="20" Watermark="Nome do produto/serviço" Text="{Binding ProductCatalogModule.Form.Name}" />
                </StackPanel>

                <StackPanel Grid.Row="2" Spacing="4">
                  <TextBlock Opacity="0.78" Text="Categoria" />
                  <TextBox TabIndex="21" Watermark="Ex.: Serviços, Software, Equipamentos" Text="{Binding ProductCatalogModule.Form.Category}" />
                </StackPanel>

                <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="8">
                  <StackPanel Spacing="4">
                    <TextBlock Opacity="0.78" Text="Preço unitário" />
                    <TextBox TabIndex="22" Watermark="2500,00" Text="{Binding ProductCatalogModule.Form.UnitPrice}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Opacity="0.78" Text="Tipo" />
                    <ComboBox TabIndex="23" ItemsSource="{Binding ProductCatalogModule.Form.KindOptions}" SelectedItem="{Binding ProductCatalogModule.Form.SelectedKind}" />
                  </StackPanel>
                </Grid>

                <Border Grid.Row="4" Padding="10,8" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b">
                  <CheckBox TabIndex="24" Content="Ativo para novos lançamentos" IsChecked="{Binding ProductCatalogModule.Form.IsActive}" />
                </Border>

                <Border Grid.Row="5" Padding="8" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b">
                  <Button Classes="primary-action" TabIndex="25" Padding="14,10" Click="OnRegisterProductServiceClick" Content="Cadastrar item" IsEnabled="{Binding ProductCatalogModule.CanRegister}" />
                </Border>

                <Border Grid.Row="6" Padding="8" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b">
                  <Button Classes="secondary-action" TabIndex="26" Padding="14,10" Click="OnToggleSelectedProductServiceActiveClick" Content="{Binding ProductCatalogModule.ToggleSelectedActiveButtonLabel}" IsEnabled="{Binding ProductCatalogModule.CanToggleSelectedActive}" />
                </Border>

                <Border Grid.Row="7" IsVisible="{Binding ProductCatalogModule.IsDeleteConfirmationPending}" Padding="10,8" BorderBrush="#6a3a3f" BorderThickness="1" CornerRadius="8" Background="#2a1b1d">
                  <TextBlock Opacity="0.9" Text="Confirmação pendente: clique novamente para excluir o item selecionado." TextWrapping="Wrap" />
                </Border>

                <Border Grid.Row="8" Padding="8" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b" VerticalAlignment="Top">
                  <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Classes="secondary-action" TabIndex="27" Padding="14,10" Click="OnUpdateSelectedProductServiceClick" Content="Atualizar selecionado" IsEnabled="{Binding ProductCatalogModule.CanUpdateSelected}" />
                    <Button Classes="destructive-action" Grid.Column="1" TabIndex="28" Padding="14,10" Click="OnDeleteSelectedProductServiceClick" Content="{Binding ProductCatalogModule.DeleteSelectedButtonLabel}" IsEnabled="{Binding ProductCatalogModule.CanDeleteSelected}" />
                  </Grid>
                </Border>
              </Grid>
            </Border>
          </Grid>
        </TabItem>

        <TabItem Header="Relatórios">
          <Grid Margin="4" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" RowSpacing="16">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Spacing="4" VerticalAlignment="Center">
                <TextBlock FontSize="21" FontWeight="SemiBold" Text="Relatórios financeiros" />
                <TextBlock Opacity="0.74" Text="Resumo consolidado, comparativo e breakdowns do período selecionado." />
              </StackPanel>
              <Border Grid.Column="1" Padding="12,8" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="10" Background="#151d26" VerticalAlignment="Center">
                <TextBlock FontWeight="SemiBold" Text="{Binding ReportsModule.Summary}" />
              </Border>
            </Grid>

            <Border Grid.Row="1" Padding="14" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="10" Background="#121a22">
              <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                <TextBlock FontSize="14" FontWeight="SemiBold" Text="Filtros do relatório" />
                <Grid Grid.Row="1" RowDefinitions="Auto,Auto" ColumnDefinitions="*,*,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="6">
                  <TextBlock Opacity="0.78" FontSize="12" Text="Data inicial" />
                  <TextBlock Grid.Column="1" Opacity="0.78" FontSize="12" Text="Data final" />
                  <TextBlock Grid.Column="2" Opacity="0.78" FontSize="12" Text="Tipo" />

                  <TextBox Grid.Row="1" TabIndex="10" Watermark="De (yyyy-MM-dd)" Text="{Binding ReportsModule.FilterFrom}" />
                  <TextBox Grid.Row="1" Grid.Column="1" TabIndex="11" Watermark="Até (yyyy-MM-dd)" Text="{Binding ReportsModule.FilterTo}" />
                  <ComboBox Grid.Row="1" Grid.Column="2" TabIndex="12" MinWidth="130" ItemsSource="{Binding ReportsModule.FilterTypeOptions}" SelectedItem="{Binding ReportsModule.SelectedFilterType}" />
                  <Button Classes="primary-action" Grid.Row="1" Grid.Column="3" TabIndex="13" Padding="14,8" Click="OnApplyReportFiltersClick" Content="Aplicar período" IsEnabled="{Binding ReportsModule.CanApplyFilters}" />
                  <Button Classes="secondary-action" Grid.Row="1" Grid.Column="4" TabIndex="14" Padding="14,8" Click="OnClearReportFiltersClick" Content="Limpar" IsEnabled="{Binding ReportsModule.CanClearFilters}" />
                  <Button Classes="secondary-action" Grid.Row="1" Grid.Column="5" TabIndex="15" Padding="14,8" Click="OnExportReportCsvClick" Content="Exportar CSV" IsEnabled="{Binding ReportsModule.CanExportCsv}" />
                </Grid>
              </Grid>
            </Border>

            <Border Grid.Row="2" Padding="14" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="10" Background="#111821">
              <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                <TextBlock FontSize="14" FontWeight="SemiBold" Text="Resumo do período selecionado" />
                <Border Grid.Row="1" Padding="10,8" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b">
                  <TextBlock Opacity="0.86" Text="{Binding ReportsModule.PeriodDisplay}" />
                </Border>

                <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="12">
                  <Border Padding="14" BorderBrush="#2f6147" BorderThickness="1" CornerRadius="10" Background="#182920">
                    <StackPanel Spacing="4">
                      <TextBlock FontSize="13" Opacity="0.8" Text="Receitas no período" />
                      <TextBlock FontSize="25" FontWeight="Bold" Text="{Binding ReportsModule.TotalRevenueDisplay}" />
                    </StackPanel>
                  </Border>

                  <Border Grid.Column="1" Padding="14" BorderBrush="#6a3a3f" BorderThickness="1" CornerRadius="10" Background="#2a1b1d">
                    <StackPanel Spacing="4">
                      <TextBlock FontSize="13" Opacity="0.8" Text="Despesas no período" />
                      <TextBlock FontSize="25" FontWeight="Bold" Text="{Binding ReportsModule.TotalExpenseDisplay}" />
                    </StackPanel>
                  </Border>

                  <Border Grid.Column="2" Padding="14" BorderBrush="#30506a" BorderThickness="1" CornerRadius="10" Background="#182632">
                    <StackPanel Spacing="4">
                      <TextBlock FontSize="13" Opacity="0.8" Text="Saldo no período" />
                      <TextBlock FontSize="25" FontWeight="Bold" Text="{Binding ReportsModule.NetBalanceDisplay}" />
                    </StackPanel>
                  </Border>
                </Grid>
              </Grid>
            </Border>

            <Border Grid.Row="3" Padding="14" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="10" Background="#121821">
              <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="10">
                <TextBlock FontSize="14" FontWeight="SemiBold" Text="Comparativo com período anterior" />

                <StackPanel Grid.Row="1" Spacing="3">
                  <TextBlock FontSize="12" Opacity="0.74" Text="Regra: período anterior imediato com a mesma duração do período selecionado." TextWrapping="Wrap" />
                  <TextBlock FontSize="12" Opacity="0.74" Text="Indicadores: ▲ alta | ▼ queda | ■ estável/indisponível." TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Row="2" Padding="10,8" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b">
                  <TextBlock Opacity="0.84" Text="{Binding ReportsModule.PeriodComparisonDisplay}" TextWrapping="Wrap" />
                </Border>

                <Grid Grid.Row="3" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                  <Border Padding="10,8" BorderBrush="#2d3a48" BorderThickness="1" CornerRadius="8" Background="#141c25">
                    <Grid ColumnDefinitions="110,*" ColumnSpacing="12">
                      <TextBlock FontWeight="SemiBold" Text="Receita" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1" Text="{Binding ReportsModule.RevenueComparisonDisplay}" TextWrapping="Wrap" />
                    </Grid>
                  </Border>

                  <Border Grid.Row="1" Padding="10,8" BorderBrush="#2d3a48" BorderThickness="1" CornerRadius="8" Background="#141c25">
                    <Grid ColumnDefinitions="110,*" ColumnSpacing="12">
                      <TextBlock FontWeight="SemiBold" Text="Despesa" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1" Text="{Binding ReportsModule.ExpenseComparisonDisplay}" TextWrapping="Wrap" />
                    </Grid>
                  </Border>

                  <Border Grid.Row="2" Padding="10,8" BorderBrush="#2d3a48" BorderThickness="1" CornerRadius="8" Background="#141c25">
                    <Grid ColumnDefinitions="110,*" ColumnSpacing="12">
                      <TextBlock FontWeight="SemiBold" Text="Saldo" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1" Text="{Binding ReportsModule.NetBalanceComparisonDisplay}" TextWrapping="Wrap" />
                    </Grid>
                  </Border>
                </Grid>
              </Grid>
            </Border>

            <Border Grid.Row="4" Padding="14" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="10" Background="#111821">
              <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
                <TextBlock FontSize="14" FontWeight="SemiBold" Text="Breakdown mensal" />

                <Border Grid.Row="1" Padding="10,7" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b">
                  <Grid ColumnDefinitions="2*,1.2*,1.2*,1.2*" ColumnSpacing="10">
                    <TextBlock FontWeight="SemiBold" Opacity="0.8" Text="Mês" />
                    <TextBlock Grid.Column="1" FontWeight="SemiBold" HorizontalAlignment="Right" Opacity="0.8" Text="Receitas" />
                    <TextBlock Grid.Column="2" FontWeight="SemiBold" HorizontalAlignment="Right" Opacity="0.8" Text="Despesas" />
                    <TextBlock Grid.Column="3" FontWeight="SemiBold" HorizontalAlignment="Right" Opacity="0.8" Text="Saldo" />
                  </Grid>
                </Border>

                <ListBox Grid.Row="2" TabIndex="20" BorderThickness="1" Background="Transparent" ItemsSource="{Binding ReportsModule.BreakdownByMonth}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:FinancialReportMonthlyBreakdownItemViewModel">
                      <Border Padding="11,9" BorderBrush="#24303a" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="2*,1.2*,1.2*,1.2*" ColumnSpacing="10">
                          <TextBlock FontWeight="SemiBold" Text="{Binding MonthDisplay}" />
                          <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding TotalRevenueDisplay}" />
                          <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding TotalExpenseDisplay}" />
                          <TextBlock Grid.Column="3" HorizontalAlignment="Right" Text="{Binding NetBalanceDisplay}" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>

            <Grid Grid.Row="5" ColumnDefinitions="*,*" ColumnSpacing="16">
              <Border Padding="14" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="10" Background="#111821">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
                  <TextBlock FontSize="14" FontWeight="SemiBold" Text="Breakdown por cliente" />

                  <Border Grid.Row="1" Padding="10,7" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b">
                    <Grid ColumnDefinitions="2*,1.2*,1.2*,1.2*" ColumnSpacing="10">
                      <TextBlock FontWeight="SemiBold" Opacity="0.8" Text="Cliente" />
                      <TextBlock Grid.Column="1" FontWeight="SemiBold" HorizontalAlignment="Right" Opacity="0.8" Text="Receitas" />
                      <TextBlock Grid.Column="2" FontWeight="SemiBold" HorizontalAlignment="Right" Opacity="0.8" Text="Despesas" />
                      <TextBlock Grid.Column="3" FontWeight="SemiBold" HorizontalAlignment="Right" Opacity="0.8" Text="Saldo" />
                    </Grid>
                  </Border>

                  <ListBox Grid.Row="2" TabIndex="21" BorderThickness="1" Background="Transparent" ItemsSource="{Binding ReportsModule.BreakdownByCustomer}">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:FinancialReportBreakdownItemViewModel">
                        <Border Padding="11,9" BorderBrush="#24303a" BorderThickness="0,0,0,1">
                          <Grid ColumnDefinitions="2*,1.2*,1.2*,1.2*" ColumnSpacing="10">
                            <TextBlock FontWeight="SemiBold" Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding TotalRevenueDisplay}" />
                            <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding TotalExpenseDisplay}" />
                            <TextBlock Grid.Column="3" HorizontalAlignment="Right" Text="{Binding NetBalanceDisplay}" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>
              </Border>

              <Border Grid.Column="1" Padding="14" BorderBrush="#3b4652" BorderThickness="1" CornerRadius="10" Background="#111821">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
                  <TextBlock FontSize="14" FontWeight="SemiBold" Text="Breakdown por produto/serviço" />

                  <Border Grid.Row="1" Padding="10,7" BorderBrush="#2a3542" BorderThickness="1" CornerRadius="8" Background="#15202b">
                    <Grid ColumnDefinitions="2*,1.2*,1.2*,1.2*" ColumnSpacing="10">
                      <TextBlock FontWeight="SemiBold" Opacity="0.8" Text="Produto/Serviço" />
                      <TextBlock Grid.Column="1" FontWeight="SemiBold" HorizontalAlignment="Right" Opacity="0.8" Text="Receitas" />
                      <TextBlock Grid.Column="2" FontWeight="SemiBold" HorizontalAlignment="Right" Opacity="0.8" Text="Despesas" />
                      <TextBlock Grid.Column="3" FontWeight="SemiBold" HorizontalAlignment="Right" Opacity="0.8" Text="Saldo" />
                    </Grid>
                  </Border>

                  <ListBox Grid.Row="2" TabIndex="22" BorderThickness="1" Background="Transparent" ItemsSource="{Binding ReportsModule.BreakdownByProductService}">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:FinancialReportBreakdownItemViewModel">
                        <Border Padding="11,9" BorderBrush="#24303a" BorderThickness="0,0,0,1">
                          <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="2*,1.2*,1.2*,1.2*" ColumnSpacing="10">
                            <TextBlock FontWeight="SemiBold" Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding TotalRevenueDisplay}" />
                            <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding TotalExpenseDisplay}" />
                            <TextBlock Grid.Column="3" HorizontalAlignment="Right" Text="{Binding NetBalanceDisplay}" />
                            <TextBlock Grid.Row="1" FontSize="12" Opacity="0.72" Text="{Binding CategoryDisplay}" TextTrimming="CharacterEllipsis" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>
              </Border>
            </Grid>
          </Grid>
        </TabItem>
      </TabControl>
    </Border>
  </Grid>
</Window>
